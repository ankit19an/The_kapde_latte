{% assign selected_collection = section.settings.collection %}

<section class="kl-section kl-featured-section kl-reveal" id="shopify-featured">
  <div class="kl-shell">
    <div class="kl-section-heading kl-section-heading-row">
      <div>
        <p class="kl-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2>{{ section.settings.heading }}</h2>
        <p class="kl-section-copy">{{ section.settings.copy }}</p>
      </div>
    </div>

    <div class="kl-product-grid">
      {% if selected_collection != blank and selected_collection.products_count > 0 %}
        {% for product in selected_collection.products limit: section.settings.products_to_show %}
          <article class="kl-product-card">
            <a class="kl-product-visual-wrap" href="{{ product.url }}">
              {% if product.featured_image != blank %}
                {{
                  product.featured_image
                  | image_url: width: 900
                  | image_tag:
                    class: 'kl-product-image',
                    loading: 'lazy',
                    alt: product.title
                }}
              {% else %}
                <div class="kl-product-visual kl-product-visual-{{ forloop.index }}"></div>
              {% endif %}
            </a>

            <div class="kl-product-meta">
              {% if product.tags.size > 0 %}
                <p class="kl-product-tag">{{ product.tags.first }}</p>
              {% endif %}

              <h3>
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>

              <p class="kl-product-copy">
                {% if product.description != blank %}
                  {{ product.description | strip_html | truncate: 110 }}
                {% else %}
                  Crafted for repeat wear with a relaxed feel and a polished finish.
                {% endif %}
              </p>

              <div class="kl-product-row">
                <span class="kl-price">{{ product.price | money_without_trailing_zeros }}</span>

                {% if product.available %}
                  {% form 'product', product, class: 'kl-product-form' %}
                    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                    <button class="kl-button kl-button-dark" type="submit">Add to bag</button>
                  {% endform %}
                {% else %}
                  <span class="kl-sold-out">Sold out</span>
                {% endif %}
              </div>
            </div>
          </article>
        {% endfor %}
      {% else %}
        {% for index in (1..3) %}
          <article class="kl-product-card">
            <div class="kl-product-visual kl-product-visual-{{ index }}"></div>
            <div class="kl-product-meta">
              <p class="kl-product-tag">Theme editor ready</p>
              <h3>Connect a collection</h3>
              <p class="kl-product-copy">
                Choose a collection in this section and Shopify will populate the product cards automatically.
              </p>
              <div class="kl-product-row">
                <span class="kl-price">Rs. --</span>
                <span class="kl-sold-out">Awaiting products</span>
              </div>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "KapdeLatte featured products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Featured products"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built for browsing now, ready to grow into a fuller storefront."
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "Connect a collection to this section and Shopify will handle products, variants, and cart submissions."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 3,
      "max": 9,
      "step": 1,
      "default": 6
    }
  ],
  "presets": [
    {
      "name": "KapdeLatte featured products"
    }
  ]
}
{% endschema %}
